# Multi-Agent System Configuration
# ===========================================

# Global Default LLM Configuration
# This is used when an agent doesn't have a specific model configured
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Network Settings
LLM_TIMEOUT=120.0
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2.0

# Proxy Settings (optional, for users behind firewall)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ===========================================
# Agent-Specific Model Configurations
# ===========================================
# Each agent can have its own model configuration.
# If not specified, the global default will be used.
# 
# Format: AGENT_{ROLE}_{SETTING}
# Roles: CEO, ADVISOR, CTO, DEVELOPER, QA, DESIGNER, DOCUMENTATION
# Settings: MODEL, TEMPERATURE, MAX_TOKENS, API_KEY, BASE_URL

# CEO Agent - Strategic decisions
AGENT_CEO_MODEL=gpt-4
AGENT_CEO_TEMPERATURE=0.7
AGENT_CEO_MAX_TOKENS=8000

# Advisor Agent - Complex analysis, needs high capability
AGENT_ADVISOR_MODEL=gpt-4
AGENT_ADVISOR_TEMPERATURE=0.5
AGENT_ADVISOR_MAX_TOKENS=16000

# CTO Agent - Technical decisions
AGENT_CTO_MODEL=gpt-4
AGENT_CTO_TEMPERATURE=0.7
AGENT_CTO_MAX_TOKENS=12000

# Developer Agent - Code generation (lower temperature for more deterministic output)
AGENT_DEVELOPER_MODEL=gpt-4
AGENT_DEVELOPER_TEMPERATURE=0.3
AGENT_DEVELOPER_MAX_TOKENS=10000

# QA Engineer Agent - Testing and validation
AGENT_QA_MODEL=gpt-4
AGENT_QA_TEMPERATURE=0.5
AGENT_QA_MAX_TOKENS=8000

# Designer Agent - Creative work (higher temperature for creativity)
AGENT_DESIGNER_MODEL=gpt-4
AGENT_DESIGNER_TEMPERATURE=0.8
AGENT_DESIGNER_MAX_TOKENS=8000

# Documentation Agent - Documentation generation (can use cheaper model)
AGENT_DOCUMENTATION_MODEL=gpt-3.5-turbo
AGENT_DOCUMENTATION_TEMPERATURE=0.5
AGENT_DOCUMENTATION_MAX_TOKENS=6000

# ===========================================
# Optional: Azure OpenAI for specific agents
# ===========================================
# AGENT_CEO_AZURE_ENDPOINT=https://your-resource.openai.azure.com/
# AGENT_CEO_AZURE_DEPLOYMENT=gpt-4-deployment

# ===========================================
# ChromaDB Configuration
# ===========================================
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===========================================
# Redis Configuration (optional)
# ===========================================
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS=false

# ===========================================
# System Configuration
# ===========================================
MAX_ITERATIONS=3
DEFAULT_TEMP_PERMISSION_DURATION=30
MAX_CONTEXT_TOKENS=8000
LOG_LEVEL=INFO
